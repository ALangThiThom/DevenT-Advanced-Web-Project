	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [ { "key": "Accept", "value": "application/json" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Test User\",\n    \"email\": \"test@example.com\",\n    \"password\": \"password\",\n    \"password_confirmation\": \"password\",\n    \"role\": \"attendee\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/api/register",
							"host": [ "{{baseUrl}}" ],
							"path": [ "api", "register" ]
						}
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if(jsonData.token || jsonData.access_token) {",
									"    var token = jsonData.token ? jsonData.token : jsonData.access_token;",
									"    pm.collectionVariables.set(\"token\", token);",
									"    console.log(\"Đã lưu token thành công!\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [ { "key": "Accept", "value": "application/json" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"test@example.com\",\n    \"password\": \"password\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/api/login",
							"host": [ "{{baseUrl}}" ],
							"path": [ "api", "login" ]
						}
					}
				},
				{
					"name": "Logout",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
						},
						"method": "POST",
						"header": [ { "key": "Accept", "value": "application/json" } ],
						"url": {
							"raw": "{{baseUrl}}/api/logout",
							"host": [ "{{baseUrl}}" ],
							"path": [ "api", "logout" ]
						}
					}
				},
				{
